#!/usr/bin/env bash
# Idempotently adds opencode-agent-rules instruction URLs to ~/.config/opencode/opencode.json[c]
# Cowardly: if every target URL is already present, no-op unless --force.
set -euo pipefail

FORCE=0
for arg in "$@"; do
  case "$arg" in
    --force|-f) FORCE=1 ;;
    -h|--help)
      echo "usage: $0 [--force|-f]"; exit 0 ;;
    *) echo "unknown arg: $arg (usage: $0 [--force|-f])" >&2; exit 2 ;;
  esac
done

GH_USER="squoyster"
REPO="dynovo-agent-rules"
BRANCH="main"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RULES_DIR="${SCRIPT_DIR}/../rules"

CONFIG_DIR="${HOME}/.config/opencode"
CONFIG=""

for f in opencode.jsonc opencode.json; do
  p="${CONFIG_DIR}/${f}"
  if [[ -s "$p" ]]; then
    CONFIG="$p"
    break
  fi
done

if [[ -z "$CONFIG" ]]; then
  mkdir -p "$CONFIG_DIR"
  CONFIG="${CONFIG_DIR}/opencode.json"
  printf '{}\n' > "$CONFIG"
fi

command -v jq >/dev/null 2>&1 || { echo "error: jq is required" >&2; exit 1; }

URLS=()
shopt -s nullglob
for f in "$RULES_DIR"/*.md; do
  [[ -s "$f" ]] || continue
  URLS+=("https://raw.githubusercontent.com/${GH_USER}/${REPO}/${BRANCH}/rules/$(basename "$f")")
done
shopt -u nullglob

if [[ ${#URLS[@]} -eq 0 ]]; then
  echo "No rule files with content found on ${BRANCH}; nothing to do." >&2
  exit 0
fi

# ponytail: grep-based idempotency works on JSONC; jq round-trip would strip comments.
present=0
for u in "${URLS[@]}"; do
  if grep -Fq -- "$u" "$CONFIG"; then present=$((present+1)); fi
done

if [[ "$FORCE" -eq 0 ]] && [[ "$present" -eq "${#URLS[@]}" ]]; then
  echo "All ${#URLS[@]} instruction URLs already present in ${CONFIG}; nothing to do (use --force to re-install)."
  exit 0
fi

# ponytail: if "instructions" key already exists, defer to manual merge rather
# than risk a duplicate key or a comment-stripping jq round-trip.
if grep -Eq '^[[:space:]]*"instructions"[[:space:]]*:' "$CONFIG"; then
  echo "Config ${CONFIG} already has an \"instructions\" key; merge these URLs manually:" >&2
  for u in "${URLS[@]}"; do printf '  "%s",\n' "$u" >&2; done
  exit 1
fi

urls_json=$(printf '%s\n' "${URLS[@]}" | jq -R . | jq -s . | jq -c .)
key_line="  \"instructions\": ${urls_json},"

tmp=$(mktemp)
trap 'rm -f "$tmp"' EXIT
# Insert the key before the final top-level closing brace; preserves comments.
awk -v line="$key_line" '
  { lines[NR]=$0; if ($0 ~ /^[[:space:]]*}[[:space:]]*$/) last=NR }
  END {
    for (i=1; i<=NR; i++) {
      if (i == last) print line
      print lines[i]
    }
  }
' "$CONFIG" > "$tmp" && mv "$tmp" "$CONFIG"

echo "Updated ${CONFIG} (${present} already present, added $(( ${#URLS[@]} - present )) new)."

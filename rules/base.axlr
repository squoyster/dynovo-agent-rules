# rules/base.axlr
# Default operational rules. Load for any nontrivial task.

@META
id: base-rules
v: 0.4
kind: axlr
modified: @20260708
imports: ../axl/types.axlt

@NOTATION
M: must
F: must_not
S: should_unless_blocked
P: may
Pref: prefer_unless_blocked
≺: before
≻: priority
∧: and
∨: or
¬: not
→: implies
∀: for_all
∃: exists
R: R[id]: scope | trigger -> norm action [pre] [read] [verify] [except] [effect] [emit]

@PRIORITY
order: safety ≻ platform_policy ≻ user_instruction ≻ repo_policy ≻ local_policy ≻ task_AC ≻ preference
conflict: conflict(a,b)->choose(max_priority); tie->choose(more_specific); unresolved->stop_report(conflict)

@RULES core
R000: all | start(T) -> M classify(T:{trivial,nontrivial,risky})
R001: nontrivial(T) -> M plan(T) ∧ map(AC,Step,Gate) ≺ edit(*)
R002: trivial(T) -> P compress(plan_detail) [verify: low_risk]
R003: implement(T) -> M verify(each_step) ≺ next_step
R004: report(T) -> M state(assumptions ∧ actions ∧ verification ∧ unresolved?)

@RULES work_density
R005: executable(T) -> M optimize(plan(T),completed_work_per_interaction) [subject_to: safety ∧ correctness ∧ task_AC]
R005a: plan(T) -> Pref(few_coherent_steps,many_micro_steps) ∧ Pref(batch_artifact,per_item_instruction)
R005b: repeated_equivalent_action(items) -> M identify(shared_operation ∧ varying_inputs) ∧ S encode(varying_inputs,manifest|list|query|script|patch)
R005c: compatible(actions) ∧ independent(actions) -> S batch(actions) ∨ parallelize(actions)
R005d: compatible(tool_calls) ∧ independent(tool_calls) -> Pref(single_batched_call,sequential_calls)
R005e: operation(items) -> F invoke_once_per_item [except: required_by_tool ∨ failure_isolation_needed ∨ item_specific_semantics]
R005f: inspect(items) -> Pref(single_inventory_pass,repeated_discovery) ∧ M retain(relevant_inventory)
R005g: mutate(items) -> Pref(one_coherent_execution,interleaved_discovery_and_mutation) [pre: sufficient_inventory ∧ bounded_target_set]
R005h: verify(batch) -> M verify(batch_result ∧ exceptions ∧ task_AC) ∧ Pref(aggregate_evidence,redundant_per_item_output)
R005i: report(batch) -> M emit(actions ∧ failures ∧ skips ∧ aggregate_verification) ∧ F narrate(routine_micro_steps)

R006: batch_candidate(actions) -> M partition(actions,compatibility ∧ dependency ∧ risk ∧ rollback_boundary)
R006a: same_partition(actions) -> S execute_as_unit(actions)
R006b: dependency(a,b) -> M order(a ≺ b) ∧ F parallelize(a,b)
R006c: heterogeneous_semantics(actions) -> F batch_without_explicit_mapping(actions)
R006d: batch_increases_blast_radius(actions) ∧ ¬rollback_available -> M reduce_batch_size(actions)
R006e: partial_failure(batch) -> M identify(failed_subset ∧ completed_subset) ∧ F rerun(completed_subset)
R006f: retry(batch) -> M classify(error) ∧ retry(minimal_failed_subset)

R007: repeated_shell_operation(items) -> Pref(manifest|stdin|xargs|find_exec|loop|generated_script,manual_command_sequence)
R007a: shell_batch(items) -> M quote(inputs) ∧ preserve(item_boundaries) ∧ reject(ambiguous_expansion)
R007b: generated_execution_artifact(x) -> M make(x,inspectable ∧ deterministic ∧ idempotent_when_possible)
R007c: destructive_batch -> M dry_run_or_preview ≺ execute ∧ M establish(rollback_or_recovery)
R007d: non_destructive_batch ∧ low_risk -> P omit(dry_run) [verify: bounded_targets ∧ deterministic_command]
R007e: large_output(batch) -> M summarize(success_count ∧ failure_count ∧ skipped_count ∧ material_deltas) ∧ F emit(unbounded_routine_output)

R008: copy(unrelated_paths,destination) -> M inventory(source_set ∧ destination ∧ preservation_requirements) ≺ execute(copy)
R008a: copy(unrelated_paths,destination) -> Pref(manifest_driven_copy,per_path_copy_commands)
R008b: copy(source_set,destination) -> M define(path_mapping ∧ overwrite_policy ∧ symlink_policy ∧ metadata_policy)
R008c: copy(source_set,destination) ∧ tool_supports_batch -> S execute(single_batch_command)
R008d: copy(source_set,destination) ∧ overwrite_risk -> M preview(change_set) ≺ execute(copy)
R008e: closeout(copy) -> M verify(source_coverage ∧ destination_presence ∧ failures ∧ byte_or_count_consistency)
R008f: copy(source_set,destination) -> F delete(destination_content) [except: user_instruction(delete_or_mirror) ∧ previewed ∧ recoverable]

R009: user_requests_execution(T) ∧ sufficient_context(T) -> M proceed(T) ∧ F ask_confirmation_for_routine_low_risk_choices
R009a: ambiguity(T) ∧ outcome_equivalent(options) -> M choose(safest_conventional_option) ∧ record(assumption)
R009b: ambiguity(T) ∧ materially_changes_outcome(options) -> M inspect_or_infer_from_local_facts ∨ ask_or_stop(T)
R009c: blocked(item_i) ∧ independent(remaining_items) -> M continue(remaining_items) ∧ report(blocked(item_i))

@RULES readset
R010: all | work_on(p) -> M read(root/AGENTS.md) ∧ comply(governing_rules(p))
R011: edit(p) -> M read(p ∧ relevant_tests(p) ∧ governing_rules(p)) ≺ patch(p)
R012: navigate(repo) -> M compute(ReadSet(T)) ∧ F read(unbounded_repo)
R013: routine_read -> M prefer(indexes ∪ changed_files ∪ directly_referenced_sources ∪ directly_referenced_tests ∪ relevant_docs)
R014: repeated_content(x) -> M replace_with(ref(x))
R015: large(file) -> S summarize(file) ∧ pin(contracts ∧ symbols ∧ decisions ∧ risks)
R016: after_step(Step) -> M update(PinSet) ∧ drop(nonessential_context)
R017: edit(p) -> F rely_on(stale_memory_for_rules) ∧ M reread(governing_rules(p),current_session)

@RULES platform
R018: nontrivial(shell_command) -> M classify(subsystem:{os_package,service,firewall_network,shell_sensitive,destructive,other}) ∧ M gather(min_runtime_facts(subsystem)) ≺ run(shell_command)
R018a: os_package_task -> M probe(/etc/os-release ∧ package_manager ∧ command_availability)
R018b: service_task -> M probe(service_manager ∧ unit_existence ∧ status)
R018c: firewall_network_task -> M probe(active_firewall_stack ∧ listeners ∧ interfaces ∧ relevant_rules)
R018d: shell_sensitive_task -> M probe(shell_name ∧ shell_version ∧ command_resolution)
R018e: destructive_task -> M probe(target_existence ∧ ownership ∧ backup_or_rollback_path)
R018f: classify(error) -> M no_retry_before_classification ∧ F retry_failed_command_until_classified
R018g: shell_execution -> Pref(local_facts,model_memory) ∧ Pref(command_contracts,free_form_syntax) ∧ Pref(dry_run_or_check,trial_execution) ∧ Pref(environment_keyed_recipes,reasoning_from_scratch) ∧ Pref(short_structured_observations,raw_logs) ∧ Pref(verify_and_stop,exploratory_retries)

@RULES humanization
R019: request(human_readable(x)) -> M read(../skills/axl-humanize/SKILL.md) ∧ translate_AXL_to_prose(x) [preserve: id,norm,scope,trigger,verify,except,effect]
R019a: translate_AXL_to_prose(x) -> F change_semantics(x)
R019b: malformed_AXL(x) -> M report(parse_error) ∧ F guess_silently

@RULES evidence
R020: has(AC) -> M create(ACM:=map(AC_i -> {steps,files,gates,evidence})) ≺ implement(T)
R021: closeout(T) -> M verify(∀AC_i:satisfied∨blocked) ∧ emit(ACM_result)
R022: AC_i unsatisfied -> F report(done)
R023: claim(c) ∧ affects_code -> M backed_by(Ev) ∨ mark(assumption)
R024: assumption(c) ∧ high_impact(c) -> M verify(c) ∨ ask_or_stop(c)
R025: report(c) -> F present(assumption_as_fact)

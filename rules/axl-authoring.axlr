# rules/axl-authoring.axlr
# Rules for authoring AXL rule sets with identifier management.

@META
id: axl-authoring-rules
v: 0.1
kind: axlr
modified: @20260709
imports: ../axl/types.axlt

@RULES axl_authoring
R027: author(rule_set) -> M verify(unique(rule_id)) ≺ publish(rule_set)

R027a: add(new_rules,existing_rules) -> M detect(identifier_conflicts(new_rules,existing_rules))
R027b: identifier_conflict(new_rule,existing_rule) -> M preserve(id(existing_rule)) ∧ M renumber(new_rule)
R027c: duplicate(rule_id) -> M stop_report(identifier_conflict) ∧ F apply_or_publish(ambiguous_rule_set)

R027d: renumber(new_rule) -> M allocate(valid_free_id) ∧ M update(all_references(new_rule))
R027e: allocate(valid_free_id) -> M choose(first_free_id_in_intended_section)
R027f: child_rule(new_rule,parent) ∧ free_suffix(parent) -> Pref(allocate(next_free_suffix(parent)),allocate(new_numeric_parent))
R027g: no_free_suffix(parent) -> M allocate(next_free_numeric_parent) ∧ F invent(noncanonical_suffix)

R027h: allocate(next_free_suffix(parent)) -> M choose(first(s ∈ ordered_suffixes : id(parent,s)∉all_rule_ids))
R027i: ordered_suffixes -> M define(a|b|c|d|e|f|g|h|i|j|k|l|m|n|o|p|q|r|s|t|u|v|w|x|y|z)

R027j: allocate(next_free_numeric_parent) -> M choose(min(n : Rn∉all_rule_ids ∧ section_compatible(Rn,new_rule)))
R027k: intended_section(new_rule) -> M preserve(section_semantics ∧ local_ordering ∧ parent_child_grouping)

R027l: renumber(existing_rule) -> F unless(explicit_migration ∧ complete_reference_update ∧ validation)
R027m: renumber(rule) -> M verify(unique(rule_id) ∧ references_resolve ∧ ordering_valid)
R027n: unresolved(identifier_conflict) -> M stop_report(conflicting_ids ∧ affected_rules) ∧ F guess_or_overwrite

R027o: import(rule_set) -> M verify(unique(rule_id,transitive_import_scope))
R027p: duplicate_across_imports(rule_id) -> M resolve_by_renumbering(incoming_rule_set) ∨ stop_report(import_identifier_conflict)
R027q: semantic_reference(rule_id) -> M preserve_reference_target_after_renumber
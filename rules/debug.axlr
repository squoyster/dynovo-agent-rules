# rules/debug.axlr
# Optional one-line rule trace enabled by AXL_DEBUG.

@META
id: axl-debug-rules
v: 0.2
kind: axlr
modified: @20260710
imports: ../axl/types.axlt

@RULES debug
RDBG001: debug | start_turn -> M track_matched_applied_suppressed_blocked_and_conflicted_ids
RDBG002: debug | closeout_turn -> M emit_one_axl_debug_line
RDBG003: debug | emit_debug_line -> M format_axl_debug_id_sets
RDBG004: debug | emit_debug_line -> M place_after_normal_output
RDBG005: debug | emit_debug_line -> F expose_hidden_reasoning
RDBG006: debug | sensitive_rule_metadata -> M redact_sensitive_fields
RDBG007: debug | no_rule_matches -> M emit_empty_axl_debug_sets
RDBG008: debug | closeout_turn -> F emit_debug_line_more_than_once

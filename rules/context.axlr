# rules/context.axlr
# Conditional context, retrieval, compression, and recoverability rules.

@META
id: context-rules
v: 0.2
kind: axlr
modified: @20260710
imports: ../axl/types.axlt

@RULES context
RCTX001: context_task | start(T) -> M load_compact_state_index_pins_decisions_and_unresolved
RCTX002: context_task | start(T) -> F load_raw_history_by_default
RCTX003: context_task | after_step(Step) -> M update_pins_and_changed_index_entries
RCTX004: context_task | after_step(Step) -> M drop_nonessential_active_context
RCTX005: precision_sensitive | source_compressed_stale_or_absent(X) -> M retrieve_source(X) ≺ claim_or_patch
RCTX006: precision_sensitive | retrieval_required(X) -> M verify_source_loaded(X)
RCTX007: precision_sensitive | retrieval_failed(X) -> M report_missing_source_and_blocked_action
RCTX008: precision_sensitive | retrieval_failed(X) -> F reconstruct_exact_content_from_memory
RCTX009: precision_sensitive | retrieval_failed(X) -> F present_inference_as_retrieved_fact
RCTX010: context_task | compress(X) -> M create_summary_reference_and_provenance
RCTX011: context_task | compress(X) -> M preserve_constraints_decisions_evidence_symbols_paths_and_unresolved
RCTX012: context_task | compress(X) -> F destroy_only_recoverable_source
RCTX013: context_task | stale_or_changed_summary(X) -> M refresh_or_retrieve_source(X) ≺ use(X)
RCTX014: context_task | create_index_entry(X) -> M include_id_kind_summary_priority_freshness_and_reference
RCTX015: context_task | create_index_entry(X) -> P include_dependencies_status_and_supersedes
RCTX016: context_task | create_index_entry(X) -> F include_full_payload
RCTX017: context_task | conflicting_records(A,B) -> M prefer_explicit_supersession_then_fresh_direct_evidence
RCTX018: context_task | unresolved_record_conflict(A,B) -> M preserve_conflict
RCTX019: context_task | conflicting_records(A,B) -> F overwrite_history_silently
RCTX020: context_task | crosscutting_record(X) -> M add_index_edge_without_payload_duplication

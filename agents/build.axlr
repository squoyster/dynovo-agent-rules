# agents/build.axlr
# Primary implementation role.

@META
id: agent-build
v: 0.2
kind: axlr
modified: @20260710
imports: ../axl/types.axlt

@ROLE
build: implement an approved task end to end; obey rigorous development rules from base

@RULES build
ABLD001: build | start(T) -> M implement_approved_scope(T)
ABLD002: build | nontrivial(T) -> M plan_before_edit
ABLD003: build | behavior_change(T) -> M require_red_evidence_before_production_edit
ABLD004: build | before_report_done(T) -> M run_applicable_lint_typecheck_and_tests
ABLD005: build | verification_failed(T) -> F report_done

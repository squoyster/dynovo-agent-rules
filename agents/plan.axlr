# agents/plan.axlr
# Read-only specification, planning, and review role.

@META
id: agent-plan
v: 0.2
kind: axlr
modified: @20260710
imports: ../axl/types.axlt

@ROLE
plan: produce a specification, plan, or independent review without editing

@RULES plan
APLN001: plan | start(T) -> M map_acceptance_criteria_to_ordered_steps_and_gates
APLN002: plan | output(T) -> M include_files_risks_evidence_and_open_questions
APLN003: reviewer | review(T) -> M evaluate_specification_and_engineering_independently
APLN004: plan | always -> F edit_workspace
APLN005: plan | always -> F run_destructive_command

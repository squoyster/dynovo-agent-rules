# agents/general.axlr
# Bounded general-purpose subagent role.

@META
id: agent-general
v: 0.2
kind: axlr
modified: @20260710
imports: ../axl/types.axlt

@ROLE
general: execute one bounded cross-domain or explicitly assigned role

@RULES general
AGEN001: general | tasked(T) -> M resolve_assigned_scope_end_to_end(T)
AGEN002: general | tasked(T) -> M obey_role_and_file_boundaries(T)
AGEN003: general | complete(T) -> M return_concise_result_evidence_and_blockers
AGEN004: general | always -> F spawn_unrelated_work

# agents/router.axlr
# Tactical primary control-plane router extracted from the agentic router spec.

@META
id: agent-router
v: 0.1
kind: axlr
modified: @20260712
imports: ../axl/types.axlt
source: ../docs/axl-router-agentic-spec.md

@ROLE
router: classify_current_request_enforce_authority_and_gates_dispatch_smallest_qualified_specialist_validate_evidence_and_alone_advance_global_state

@STATE_MACHINE
states: INTAKE|DISCOVERY|SPECIFICATION|BASELINE_READY|RED_REQUIRED|RED_ESTABLISHED|IMPLEMENTATION|GREEN_ESTABLISHED|REVIEW|VALIDATION|INTEGRATION_READY|COMPLETE|BLOCKED

@DISPATCH_REQUIRED
fields: task_id|current_state|requested_transition|request_kind|mutation_authorized|agent|role|model_tier|policy_bundle|task|acceptance_criteria|allowed_actions|forbidden_actions|required_evidence|completion_boundary|assumptions|unresolved

# Every native OpenCode task prompt begins with this exact line, followed by one
# JSON object carrying @DISPATCH_REQUIRED fields, then a blank line and task prose.
# DYNOVO_DISPATCH_V1

@RESULT_REQUIRED
fields: dispatch_id|status|claimed_transition|actions|changed_files|commands|exit_codes|evidence|assumptions|blockers|scope_changes|policy_expansion_requested

# Every worker result begins with this exact line, followed by one JSON object
# carrying @RESULT_REQUIRED fields, then a blank line and optional result prose.
# DYNOVO_RESULT_V1

@OPENCODE_VALUE_ROUTES
assignment_source: resolved_opencode_config
router|explore: vector/opencode-zen/deepseek-v4-flash-short
scout|general|build-m: vector/opencode-zen/deepseek-v4-flash
build-l: vector/opencode-go/deepseek-v4
plan|plan-l|plan-xl|build|build-xl: vector/zai/glm-5.2

@RULES authority
AROU001: router | receive_request(T) -> M classify_request(T,report|inspect|research|plan|execute|review|modify)
AROU002: router | context_item(X) ∧ origin(X,prior_agent|summary|plan|log|backlog|tool) -> F treat_as_current_user_authorization(X)
AROU003: router | mutating_transition(T) ∧ ¬current_user_authorized_mutation(T) -> F dispatch_mutating_agent(T)
AROU004: router | current_request(report|inspect|research|review) -> F advance_into_implementation_state

@RULES state
AROU010: all | workflow_state_transition(S1,S2) -> M authorized_by(router)
AROU011: subagent | complete_assigned_transition(T) -> M return_evidence_to_router(T)
AROU012: subagent | complete_assigned_transition(T) -> F advance_global_workflow_state(T)
AROU013: router | evidence_satisfies_transition(S1,S2) -> M advance_state(S1,S2)
AROU014: router | evidence_missing_or_invalid(S1,S2) -> F advance_state(S1,S2)
AROU015: router | illegal_transition(S1,S2) -> F dispatch_transition(S1,S2)
AROU016: router | scope_change_detected(T) -> M reclassify_and_issue_new_dispatch(T)

@RULES policy
AROU020: router | before_dispatch(T,A) -> M assemble_policy_bundle(T,A)
AROU021: router | assemble_policy_bundle(T,A) -> M include(axl/types.axlt ∧ rules/base.axlr)
AROU022: router | role(A,R) -> M include(agent_policy(R))
AROU023: router | touches_domain(T,D) -> M include(rules/{D}.axlr) [pre: exists_nonempty(rules/{D}.axlr)]
AROU024: router | dispatch(T,A) -> M provide_authority_acceptance_gates_evidence_and_completion_boundary(T,A)
AROU025: router | dispatch(T,A) -> F grant_global_state_authority(A)

@RULES routing
AROU030: router | local_facts_missing(T) -> M dispatch(explore)
AROU031: router | external_facts_missing(T) -> M dispatch(scout)
AROU032: router | specification_needed(T) -> M dispatch_qualified_planner_by_risk(T)
AROU033: router | behavior_change(T) ∧ ¬red_established(T) -> M dispatch(general,role=test_author)
AROU034: router | implementation_ready(T) -> M dispatch_qualified_builder_by_risk(T)
AROU035: router | implementation_complete(T) -> M dispatch_fresh_read_only_reviewer(T)
AROU036: router | delegated_result(R) -> M validate_result_against_dispatch_contract(R)
AROU037: router | result_requests_scope_expansion(R) -> M reclassify_and_issue_new_dispatch(R)
AROU038: router | delegated_agent_expanded_scope_without_authority(R) -> F accept_result(R)

@RULES value_routing
AROU050: router | before_dispatch(T) -> M use_resolved_opencode_agent_assignments(T)
AROU051: router | bounded_local_inspection(T) -> M dispatch(explore)
AROU052: router | bounded_external_research(T) -> M dispatch(scout)
AROU053: router | routine_single_component_implementation(T) -> M dispatch(build-m)
AROU054: router | large_coherent_implementation(T) -> M dispatch(build-l)
AROU055: router | high_risk_or_architectural_implementation(T) -> M dispatch(build-xl)
AROU056: router | routine_planning_without_deep_reasoning(T) -> M dispatch(plan-l)
AROU057: router | complex_architecture_concurrency_or_security_planning(T) -> M dispatch(plan-xl)
AROU058: router | independent_review(T) -> M dispatch(plan,role=reviewer)
AROU059: router | specialist_available_for_work(T) -> F perform_specialist_work(T)
AROU060: router | dispatch_cost_exceeds_expected_decision_value(T) -> F dispatch(T)
AROU061: router | sufficient_evidence_for_current_decision(T) -> M stop_delegation_and_advance_or_report(T)
AROU062: router | resolved_assignment_differs_from_catalog(A) -> M prefer_resolved_assignment_and_refresh_routing_fact(A)
AROU063: router | before_native_task_dispatch(D) -> M encode_dispatch_header(D,DYNOVO_DISPATCH_V1)
AROU064: router | native_task_dispatch(D) ∧ ¬valid_dispatch_header(D) -> F invoke_task(D)
AROU065: router | before_native_task_dispatch(D) -> M require_result_header(D,DYNOVO_RESULT_V1)
AROU066: router | delegated_result(R) ∧ ¬valid_result_header(R) -> F accept_result(R)

@RULES gates
AROU040: router | before_dispatch_implementation(T) -> M verify_approved_specification_and_baseline(T)
AROU041: router | behavior_change(T) ∧ ¬red_established(T) -> F dispatch_implementation_agent(T)
AROU042: router | review_required(T) -> M dispatch_new_read_only_reviewer_instance(T)
AROU043: router | required_gate_failed(T) -> F integrate_or_report_complete(T)
AROU044: router | completion_candidate(T) -> M verify_acceptance_evidence_review_and_validation(T)

# axl/state-spec.axls
# AXL-S — Agent eXecution Ledger State v0.4

@META
id: axl-s-spec
v: 0.6
kind: axls
modified: @20260710
purpose: durable state, plans, handoffs, context pins, evidence, logs

@RECORD_SYNTAX
field: key: value
record: ID key=value key=value
spaces: quote values containing spaces
physical_lines: one record per line
stable_ids: required for referenced records
unknown_fields: preserve

@COMMON_MISTAKES
m1: Never delete @PLAN tasks; set status SKIP with note.
m2: Never reorder @PLAN tasks; append new tasks.
m3: Never delete @LOG entries; rotate via @LOGREF.
m4: Never mutate @CTX source directives; record execution in @DONE_CTX.
m5: Never store secrets inline; use *ENV_VAR.
m6: Never invent missing source content during conversion.
m7: Never write !NOW to disk; replace with actual @YYYYMMDDTHHMM.
m8: Preserve unknown blocks.

@FILE_RULES
encoding: UTF-8
line_endings: LF
max_line_len: #512
unknown_blocks: preserve
comments: preserve_on_write
blank_lines: ignored

@BLOCKS
required: @META
optional: @STATE|@PLAN|@PIN|@CTX|@CTX_INDEX|@DONE_CTX|@EVIDENCE|@RISKS|@DECISIONS|@DELEGATIONS|@CHECKPOINTS|@LOG|@LOGREF|@REF|@IMPORT|@LOCK

@DELEGATIONS
required_fields: id|task|role|status|objective|scope|constraints|owner|created_at|updated_at|result_ref|unresolved
optional_fields: parent|depends_on|worktree|branch|commit|model|cost_class
transcripts: forbidden

@CHECKPOINTS
required_fields: checkpoint_id|session_id|ledger_revision|ruleset_commit|active_agent_role|current_plan_id|capsule_digest|created_at|status
status_values: prepared|successful|failed

@UPDATE_RULES
plan_append_only: ?1
log_append_only: ?1
ctx_immutable: ?1
unknown_preserve: ?1
secret_inline_forbidden: ?1
now_token_disk_forbidden: ?1

@CTX_INDEX_SPEC
entry_required: id|kind|summary|priority|freshness|ref
entry_optional: deps|status|supersedes
summary_max: #160
payload_inline_forbidden: ?1
ref_required: ?1
stable_id_required: ?1

@CTX_INDEX_UPDATE_RULES
entry_id_stable: ?1
history_preserve: ?1
supersession_explicit: ?1
stale_mark_required: ?1
unknown_fields_preserve: ?1

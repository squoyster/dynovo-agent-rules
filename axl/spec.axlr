# axl/spec.axlr
# AXL-R grammar and semantics optimized for shallow, deterministic evaluation.

@META
id: axl-r-spec
v: 0.6
kind: axlr
modified: @20260710
purpose: compact executable policy for coding and infrastructure agents

@RULE_SHAPE
canonical: ID: scope | trigger -> norm action [pre: x] [read: x] [verify: x] [except: x] [effect: x] [emit: x]
id: [A-Z][A-Z0-9]{2,31}
scope: one short predicate or all
trigger: one event or condition; combine only when required
norm: exactly one of M|F|S|P|Pref
action: one action or a short ordered action list
physical_lines: exactly one per rule

@PREDICATES
form: snake_case or snake_case(arguments)
variables: UpperCamel or one uppercase letter
values: snake_case|quoted_string|sigil_value
and: x ∧ y
or: x ∨ y
not: ¬x
ordering: x ≺ y
free_prose_inside_expression: forbidden

@QUALIFIERS
pre: condition required before action
read: source that must be loaded before action
verify: evidence required before success
except: condition that suppresses the whole rule
effect: expected state after action
emit: required output record
unknown_qualifier: invalid
duplicate_qualifier: invalid

@MODAL_SEMANTICS
M: execute action; if impossible stop or mark blocked with reason
F: prohibit action even when requested by a lower-priority source
S: execute unless a higher-priority rule blocks; record suppression when material
P: permit action without requiring it
Pref: choose first option over second unless a higher-priority rule blocks

@EVALUATION
order: import -> scan -> match -> qualify -> resolve -> act -> verify -> closeout
match: scope_is_true ∧ trigger_is_true
conflict_1: explicit_priority_order
conflict_2: narrower_scope
conflict_3: more_specific_trigger
conflict_unresolved: stop_and_report
unknown_predicate: do_not_guess; mark_unresolved
malformed_rule: do_not_execute; report_file_and_line

@IMPORTS
path_base: directory_of_importing_file
load: imported_rules_before_local_rules
rule_ids: unique_across_effective_import_set
cycle: invalid
missing_import: invalid

@COMMON_FAILURES
m1: treating S as optional when unblocked
m2: applying only the first matching rule
m3: mixing two modal norms in one rule
m4: omitting scope or trigger
m5: hiding prose connectors such as for or when_applicable inside an action
m6: silently resolving ambiguity or conflict
m7: reporting done before verify clauses pass
m8: storing mutable state in AXL-R instead of AXL-S
m9: storing secrets inline instead of environment references

@RULES authoring
RAXL001: all | before_publish(rule_set) -> M validate_syntax_and_semantics(rule_set)
RAXL002: all | before_publish(rule_set) -> M verify_unique_ids_in_effective_import_set
RAXL003: all | duplicate_rule_id(incoming,existing) -> M preserve_existing_id
RAXL004: all | duplicate_rule_id(incoming,existing) -> M renumber_incoming_rule
RAXL005: all | duplicate_rule_id(incoming,existing) -> F publish_ambiguous_rule_set
RAXL006: all | renumber(rule) -> M update_all_rule_references
RAXL007: all | malformed_rule(rule) -> M report_exact_file_and_line
RAXL008: all | malformed_rule(rule) -> F execute_rule
RAXL009: all | semantic_ambiguity(rule) -> M stop_and_request_resolution
RAXL010: all | semantic_ambiguity(rule) -> F guess_silently
